# ============================================================
# contracts/.env — configuração para deploy e verificação
# NUNCA versione este arquivo com valores reais
# Adicione .env ao .gitignore (já está incluído)
# ============================================================

# Chave privada do deployer
# NUNCA compartilhe — use apenas localmente para deploy
DEPLOYER_PRIVATE_KEY=

# RPC da Base (público — não precisa de chave)
BASE_RPC_URL=https://mainnet.base.org

# RPC do Sepolia (para testes antes de ir à mainnet)
# Obtenha em https://alchemy.com ou https://infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/SUA_KEY_AQUI

# Basescan — para verificar o código do contrato na Base
# Obtenha em https://basescan.org/myapikey
BASESCAN_API_KEY=

# Etherscan — para verificar na Sepolia
ETHERSCAN_API_KEY=

# Carteira que receberá as taxas da plataforma (5%)
# Este é um endereço PÚBLICO — não é uma chave privada
PLATFORM_WALLET=0xb7516B25F52Ea4Cf3711D6fa83F844756209c07d

# 0x quote API (backend only; never expose a real key in Git)
ZEROX_API_KEY=your_0x_api_key_here
