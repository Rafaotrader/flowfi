# =========================
# SERVER
# =========================
PORT=5000
FRONTEND_URL=http://localhost:5173

# =========================
# SWAP / 0x
# =========================
ZEROX_API_KEY=your_0x_api_key_here
PLATFORM_SWAP_FEE_BPS=50

# =========================
# REDE PADRÃO
# =========================
# Base é a rede principal do FlowFi (gas reduzido)
DEFAULT_CHAIN_ID=8453
RPC_URL=https://mainnet.base.org

# =========================
# SUBGRAPH DA BASE (rede principal)
# API key gratuita em https://thegraph.com/studio/
# =========================
BASE_SUBGRAPH_URL=

# =========================
# SUBGRAPH ETHEREUM (suporte secundário)
# =========================
ETHEREUM_SUBGRAPH_URL=

# Outras redes (opcional — deixe vazio para usar mocks)
ARBITRUM_SUBGRAPH_URL=
OPTIMISM_SUBGRAPH_URL=
POLYGON_SUBGRAPH_URL=

# =========================
# RPC URLs (públicos, sem chave)
# =========================
RPC_BASE=https://mainnet.base.org
RPC_ETHEREUM=https://eth.llamarpc.com
RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_OPTIMISM=https://mainnet.optimism.io
RPC_POLYGON=https://polygon-rpc.com

# =========================
# PLATAFORMA
# Taxa fixa: 5% sobre fees sacados (nunca sobre capital)
# =========================
PLATFORM_FEE_BPS=500
# IMPORTANTE: substitua pelo endereço real antes de deployar
PLATFORM_WALLET=0x0000000000000000000000000000000000000000

# =========================
# CONTRATO HARVESTER (preencher após deploy na Base)
# =========================
HARVESTER_CONTRACT_ADDRESS=

# =========================
# BANCO DE DADOS (opcional)
# =========================
DATABASE_URL=

# =========================
# BASESCAN / ETHERSCAN (para verificação do contrato)
# NUNCA versione chaves privadas — use apenas em ambiente local
# =========================
BASESCAN_API_KEY=
ETHERSCAN_API_KEY=
